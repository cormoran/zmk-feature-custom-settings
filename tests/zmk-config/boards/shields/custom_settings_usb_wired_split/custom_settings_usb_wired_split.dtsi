/*
 * Shared devicetree for the custom_settings_usb_wired_split shield -- a minimal
 * two-part WIRED split for `west zmk-renode-test --mode wired-split` (= the
 * usb-host-link x wired-split-link combination).
 *
 * Topology (see the repo README's "Hardware-free split-relay test"):
 *
 *   host --USB(Studio)--> CENTRAL(left) --wired(split relay)--> PERIPHERAL(right)
 *
 * Both halves (custom_settings_usb_wired_split_left = central,
 * custom_settings_usb_wired_split_right = peripheral) include this. Patterned on
 * zmk-west-commands' renode_wired_split (wired split link on uart1, console on
 * uart0) crossed with the Studio-ready physical-layout shape (a
 * zmk,physical-layout with key_physical_attrs and NO chosen zmk,matrix-transform
 * -- CONFIG_ZMK_STUDIO on the central build-asserts on exactly that shape; the
 * transform is referenced from the physical layout instead).
 *
 * Neither half carries any local sensor: the peripheral only runs the
 * custom-settings split RPC relay's peripheral role, so a Studio host talking to
 * the central over USB can read/write the PERIPHERAL's settings across the wired
 * split event relay.
 *
 * Renode gotchas (identical to the renode-studio-uart snippet / renode_wired_split):
 * the stock xiao_ble enables &qspi/&p25q16h (external NOR) whose readiness
 * events Renode does not model, so that driver busy-waits forever -- disable it.
 * Disable the board's console-over-USB CDC (board_cdc_acm_uart) so the console
 * stays on uart0; the central keeps &usbd ENABLED for the Studio CDC (its
 * _left.overlay does nothing extra), the peripheral disables &usbd in its own
 * overlay (it needs no USB).
 */
#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

&qspi {
	status = "disabled";
};

&p25q16h {
	status = "disabled";
};

&board_cdc_acm_uart {
	status = "disabled";
};

&pinctrl {
	uart1_default: uart1_default {
		group1 {
			psels = <NRF_PSEL(UART_TX, 0, 2)>;
		};
		group2 {
			psels = <NRF_PSEL(UART_RX, 0, 3)>;
			bias-pull-up;
		};
	};

	uart1_sleep: uart1_sleep {
		group1 {
			psels = <NRF_PSEL(UART_TX, 0, 2)>,
					<NRF_PSEL(UART_RX, 0, 3)>;
			low-power-enable;
		};
	};
};

&uart0 {
	status = "okay";
};

&uart1 {
	compatible = "nordic,nrf-uarte";
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart1_default>;
	pinctrl-1 = <&uart1_sleep>;
	pinctrl-names = "default", "sleep";
};

/ {
	chosen {
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zmk,kscan = &kscan0;
		/* NO zmk,matrix-transform chosen -- CONFIG_ZMK_STUDIO (central)
		 * build-asserts against it; the transform is referenced from the
		 * physical layout instead. */
	};

	kscan0: kscan {
		compatible = "zmk,kscan-gpio-direct";
		input-gpios
			= <&xiao_d 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
			, <&xiao_d 1 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
			, <&xiao_d 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
			, <&xiao_d 3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
			;
	};

	transform0: keymap_transform {
		compatible = "zmk,matrix-transform";
		columns = <2>;
		rows = <2>;
		map = <
		RC(0,0)  RC(0,1)
		RC(1,0)  RC(1,1)
		>;
	};

	physical_layout0: physical_layout0 {
		compatible = "zmk,physical-layout";
		display-name = "Custom Settings";
		transform = <&transform0>;
		keys  /* w   h    x    y   rot  rx  ry */
			= <&key_physical_attrs 100 100   0   0 0 0 0>
			, <&key_physical_attrs 100 100 100   0 0 0 0>
			, <&key_physical_attrs 100 100   0 100 0 0 0>
			, <&key_physical_attrs 100 100 100 100 0 0 0>
			;
	};

	wired_split: wired_split {
		compatible = "zmk,wired-split";
		device = <&uart1>;
	};
};
